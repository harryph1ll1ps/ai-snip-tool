{
  "name": "ai-snip-tool",
  "version": "0.1.0",
  "private": true,
  "description": "A macOS snipping workflow that opens an AI chat over the captured screenshot.",
  "type": "module",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "svelte-kit sync && electron-vite build",
    "preview": "electron-vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.37.0",
    "@sveltejs/vite-plugin-svelte": "^6.1.4",
    "@types/node": "^22.18.3",
    "electron": "^38.0.0",
    "electron-vite": "^4.0.0",
    "svelte": "^5.38.7",
    "svelte-check": "^4.3.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.4"
  }
}
